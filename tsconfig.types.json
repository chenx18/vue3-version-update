{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "declaration": true,
    "emitDeclarationOnly": true,
    "declarationMap": false,
    "sourceMap": false,
    "skipLibCheck": true,
    "outDir": "./dist",
    "rootDir": "./src/runtime",
    "types": ["vite/client", "node"]
  },
  "include": [
    "src/runtime/**/*.ts",
    "src/runtime/**/*.d.ts"
  ]
}
