{
  "name": "vue3-version-update",
  "version": "1.0.0",
  "description": "Vue3 前端版本更新运行时公共包，统一处理版本探测、更新提示与待更新标识。",
  "type": "module",
  "license": "MIT",
  "author": "chenx18_cn",
  "keywords": [
    "vue3",
    "version-update",
    "version-check",
    "update-notifier",
    "micro-frontend",
    "wujie"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "node ./scripts/build.mjs",
    "prepublishOnly": "npm run build",
    "pack:check": "npm pack --dry-run"
  },
  "engines": {
    "node": ">=18"
  },
  "peerDependencies": {
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "vue": "^3.5.13"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  }
}
